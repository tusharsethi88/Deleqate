# ─────────────────────────────────────────────────────────────────────────
# Deleqate — PRODUCTION environment template
# Copy this file to ".env" in the project root on the production server and
# fill in REAL values. NEVER commit the real .env (.gitignore excludes it).
#
#   cp env.production.example .env   # then edit .env
#
# Once DJANGO_ENV=production is set, the app REFUSES TO BOOT unless the
# secret key, admin password, and PayU credentials below are all provided.
# ─────────────────────────────────────────────────────────────────────────

# Turns on production mode: DEBUG off, Secure/__Host- cookies, boot guards on,
# test accounts NOT seeded.
DJANGO_ENV=production

# ── Core secrets (REQUIRED in production) ───────────────────────────────────
# 64+ random hex chars. Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
DELEQATE_SECRET_KEY=CHANGE_ME_64_HEX_CHARS

# Strong, unique admin password (login at /dq-control-7x9k).
DELEQATE_ADMIN_PASSWORD=CHANGE_ME_STRONG_UNIQUE_PASSWORD

# ── PayU payment gateway (REQUIRED in production) ───────────────────────────
# Use your REAL PayU PRODUCTION key+salt. Rotate the old sandbox pair in the
# PayU dashboard before launch — it was previously committed to the repo.
PAYU_KEY=CHANGE_ME_REAL_PAYU_KEY
PAYU_SALT=CHANGE_ME_REAL_PAYU_SALT
PAYU_URL=https://secure.payu.in/_payment

# ── Hosts / CORS / frontend (set to your real domain) ───────────────────────
ALLOWED_HOSTS=deleqate.com,www.deleqate.com
CORS_ORIGINS=https://deleqate.com,https://www.deleqate.com
FRONTEND_URL=https://deleqate.com

# ── Support / payment display ───────────────────────────────────────────────
SUPPORT_WHATSAPP=919999999999
SUPPORT_UPI=deleqate@upi

# ── Optional ────────────────────────────────────────────────────────────────
# Only if you run the autopilot webhook:
# AUTOPILOT_API_TOKEN=CHANGE_ME_RANDOM_TOKEN
# Reverse-proxy IP(s) so client-IP rate limiting is accurate (comma-separated):
# TRUSTED_PROXY_IPS=10.0.0.1
# AutoPilot pilot account email + auto-assign delay (minutes):
# AUTOPILOT_EMAIL=deleqate@gmail.com
# AUTO_ASSIGN_MINUTES=10

# ── OTP (MSG91) — confirm OTP delivers in prod with NO console fallback ──────
# MSG91_AUTH_KEY=CHANGE_ME
# MSG91_TEMPLATE_ID=CHANGE_ME
# MSG91_SENDER_ID=CHANGE_ME
