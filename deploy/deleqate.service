[Unit]
Description=Deleqate Django backend (gunicorn)
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/deleqate/backend
Environment="PATH=/home/ubuntu/deleqate/backend/venv/bin"
# gunicorn serves the Django WSGI app on a local port; nginx proxies to it.
ExecStart=/home/ubuntu/deleqate/backend/venv/bin/gunicorn config.wsgi:application \
    --bind 127.0.0.1:5051 \
    --workers 3 \
    --timeout 120
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
